{
  "name": "stealth-interview",
  "version": "1.0.1",
  "private": true,
  "description": "Electron sandbox for security testing: opens a site and feeds it mocked signals (looping webcam, single monitor, fullscreen, always-active tab).",
  "main": "src/main.js",
  "author": "Stealth Interview",
  "scripts": {
    "start": "node scripts/start.js",
    "convert": "node scripts/convert.js",
    "check": "node scripts/check-inject.js",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win"
  },
  "license": "MIT",
  "dependencies": {
    "ffmpeg-static": "^5.2.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.stealthinterview.app",
    "productName": "Stealth Interview",
    "copyright": "Copyright © 2026 Stealth Interview",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "test/**/*",
      "config.json",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/ffmpeg-static/**"
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "deleteAppDataOnUninstall": true
    },
    "linux": {
      "target": "AppImage",
      "category": "Development"
    }
  }
}
